# Database connection URLs for maintenance scripts.
# Copy to scripts/db.env — never commit db.env (gitignored).
#
# Supabase Dashboard → Connect → Session pooler (port 5432) → URI
# URL-encode password special chars (@ → %40, # → %23)
#
# Prod and staging may use different pooler hosts (check Connect for each project).
# Example: prod Mumbai aws-1-ap-south-1, staging Sydney aws-1-ap-southeast-2

PROD_DB_URL="postgresql://postgres.[PROD-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
STAGING_DB_URL="postgresql://postgres.[STAGING-REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
